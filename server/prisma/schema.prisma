datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model BacktestSession {
  id              String         @id @default(uuid())
  name            String
  sourceMode      String         // CSV | WEBHOOK | MANUAL | MIXED
  symbol          String
  marketType      String         // Forex, Gold, Crypto, Index, Custom
  timeframe       String
  initialBalance  Float
  balanceCurrency String         // USD, CENT (cents), IDR
  usdIdrRate      Float
  riskMode        String         // FIXED_USD | FIXED_PCT | NO_R
  riskValue       Float
  rules           String?        // JSON string of backtest rules
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  trades          Trade[]
  invalidTrades   InvalidTrade[]
}

model Trade {
  id                    String          @id @default(uuid())
  sessionId             String
  session               BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  source                String          // CSV | WEBHOOK | MANUAL
  tradeNumber           Int?
  tradeId               String?         // webhook trade_id
  symbol                String
  timeframe             String
  side                  String          // LONG | SHORT
  entryTime             DateTime?
  exitTime              DateTime?
  entryPrice            Float?
  exitPrice             Float?
  slPrice               Float?          // Stop Loss price
  tpPrice               Float?          // Take Profit price
  qty                   Float?
  positionValue         Float?
  netPnlUsd             Float?
  netPnlPct             Float?
  netPnlIdr             Float?
  favorableExcursionUsd Float?
  favorableExcursionPct Float?
  adverseExcursionUsd   Float?
  adverseExcursionPct   Float?
  cumulativePnlUsd      Float?
  cumulativePnlPct      Float?
  durationMinutes       Int?            // Trade duration in minutes
  entrySignal           String?
  exitSignal            String?
  setupTag              String?
  mistakeTag            String?         // FOMO, Late Entry, Early Entry, No Confirmation, Against Trend, Bad SL, Moved SL, Revenge Trade, Overtrade, No Mistake
  emotionTag            String?         // Calm, Fear, Greedy, Angry, Bored, Impulsive, Confident, Tired
  confidenceRating      Int?            // 1-5
  checklistData         String?         // JSON string of checklist items
  status                String          // OPEN | CLOSED | INVALID
  result                String?         // WIN | LOSS | BE
  rMultiple             Float?
  plannedRR             Float?
  riskUsd               Float?
  notes                 String?
  screenshotUrl         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([sessionId])
  @@index([tradeId])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  source       String   @default("UNKNOWN")
  eventType    String
  payload      String
  dealId       String?  @unique // To prevent duplicate MT5 deal events
  receivedAt   DateTime @default(now())
  processed    Boolean  @default(false)
  error        String?

  // Legacy fields (optional to avoid breaking existing code if any)
  tradeId      String?
  status       String?
  errorMessage String?
}

model InvalidTrade {
  id          String          @id @default(uuid())
  sessionId   String
  session     BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tradeNumber Int
  reason      String
  rawRows     String          // JSON string of rows that caused error
  createdAt   DateTime        @default(now())

  @@index([sessionId])
}

model SystemSetting {
  key   String @id
  value String
}

model TradingAccount {
  id             String      @id @default(uuid())
  name           String
  broker         String?
  server         String?
  accountNumber  String?
  accountType    String      // DEMO | REAL | CENT | PROP | OTHER
  currency       String
  initialBalance Float
  currentBalance Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  liveTrades     LiveTrade[]
}

model LiveTrade {
  id               String          @id @default(uuid())
  tradingAccountId String
  tradingAccount   TradingAccount  @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  source           String          // MANUAL | MT5_EA | MT5_PYTHON | BROKER_API
  positionId       String?         @unique // MT5 position ID
  symbol           String
  side             String          // BUY | SELL
  lot              Float
  entryPrice       Float
  stopLoss         Float?
  takeProfit       Float?
  closePrice       Float?
  openTime         DateTime
  closeTime        DateTime?
  status           String          @default("OPEN") // OPEN | CLOSED
  commission       Float?          @default(0)
  swap             Float?          @default(0)
  profit           Float?
  profitCurrency   String?
  riskMoney        Float?
  riskPercent      Float?
  rMultiple        Float?
  magicNumber      String?
  strategyTag      String?
  emotionTag       String?
  mistakeTag       String?
  notes            String?
  followedPlan     Boolean?
  screenshots      String?         // JSON string array of URLs
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tradingAccountId])
}

model RiskCalculationPreset {
  id           String   @id @default(uuid())
  name         String
  symbol       String
  pipSize      Float    // e.g., 0.0001 or 0.01
  tickSize     Float    // e.g., 0.00001
  tickValue    Float    // e.g., 1
  contractSize Float    @default(100000)
  lotStep      Float    @default(0.01)
  minLot       Float    @default(0.01)
  maxLot       Float    @default(100)
}
