datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model BacktestSession {
  id              String         @id @default(uuid())
  name            String
  sourceMode      String         // CSV | WEBHOOK | MANUAL | MIXED
  symbol          String
  marketType      String         // Forex, Gold, Crypto, Index, Custom
  timeframe       String
  initialBalance  Float
  balanceCurrency String         // USD, CENT (cents), IDR
  centMultiplier  Float          @default(100)
  usdIdrRate      Float
  riskMode        String         // FIXED_USD | FIXED_PCT | NO_R
  riskValue       Float
  rules           String?        // JSON string of backtest rules
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  trades          Trade[]
  invalidTrades   InvalidTrade[]
  mt5ReportImports Mt5ReportImport[]
  mt5Deals       Mt5Deal[]
  mt5EquityPoints Mt5EquityPoint[]
  mt5Orders      Mt5Order[]
  mt5ReportFindings Mt5ReportFinding[]
}

model Trade {
  id                    String          @id @default(uuid())
  sessionId             String
  session               BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  source                String          // CSV | WEBHOOK | MANUAL
  tradeNumber           Int?
  tradeId               String?         // webhook trade_id
  symbol                String
  timeframe             String
  side                  String          // LONG | SHORT
  entryTime             DateTime?
  exitTime              DateTime?
  entryPrice            Float?
  exitPrice             Float?
  slPrice               Float?          // Stop Loss price
  tpPrice               Float?          // Take Profit price
  qty                   Float?
  positionValue         Float?
  netPnlUsd             Float?
  netPnlPct             Float?
  netPnlIdr             Float?
  favorableExcursionUsd Float?
  favorableExcursionPct Float?
  adverseExcursionUsd   Float?
  adverseExcursionPct   Float?
  cumulativePnlUsd      Float?
  cumulativePnlPct      Float?
  durationMinutes       Int?            // Trade duration in minutes
  entrySignal           String?
  exitSignal            String?
  setupTag              String?
  mistakeTag            String?         // FOMO, Late Entry, Early Entry, No Confirmation, Against Trend, Bad SL, Moved SL, Revenge Trade, Overtrade, No Mistake
  emotionTag            String?         // Calm, Fear, Greedy, Angry, Bored, Impulsive, Confident, Tired
  confidenceRating      Int?            // 1-5
  checklistData         String?         // JSON string of checklist items
  status                String          // OPEN | CLOSED | INVALID
  result                String?         // WIN | LOSS | BE
  rMultiple             Float?
  plannedRR             Float?
  riskUsd               Float?
  notes                 String?
  screenshotUrl         String?
  importFingerprint     String?         // stable hash for dedup
  importBatchId         String?         // links to ImportBatch.id
  importedAt            DateTime?       // when this trade was imported
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([sessionId])
  @@index([tradeId])
  @@index([importBatchId])
  @@index([importFingerprint, sessionId])
}

model ImportBatch {
  id               String   @id @default(uuid())
  sessionId        String
  fileName         String?
  mode             String   // NEW | REPLACE | APPEND | SMART_MERGE
  totalRows        Int      @default(0)
  validTrades      Int      @default(0)
  insertedTrades   Int      @default(0)
  skippedDuplicates Int     @default(0)
  invalidRows      Int      @default(0)
  importedAt       DateTime @default(now())
  notes            String?
}

model Mt5ReportImport {
  id                    String   @id @default(uuid())
  sessionId             String
  session               BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileName              String
  graphFileName         String?
  expertName            String?
  symbol                String?
  timeframe             String?
  periodStart           DateTime?
  periodEnd             DateTime?
  initialDeposit        Float?
  currency              String?
  leverage              String?
  totalNetProfit        Float?
  grossProfit           Float?
  grossLoss             Float?
  profitFactor          Float?
  expectedPayoff        Float?
  recoveryFactor        Float?
  sharpeRatio           Float?
  totalTrades           Int?
  totalDeals            Int?
  winrate               Float?
  profitTrades          Int?
  lossTrades            Int?
  shortTrades           Int?
  shortWinrate          Float?
  longTrades            Int?
  longWinrate           Float?
  balanceDrawdownMax    Float?
  balanceDrawdownPct    Float?
  equityDrawdownMax     Float?
  equityDrawdownPct     Float?
  largestProfitTrade    Float?
  largestLossTrade      Float?
  averageProfitTrade    Float?
  averageLossTrade      Float?
  maxConsecutiveWins    Int?
  maxConsecutiveLosses  Int?
  averageConsecutiveWins Float?
  averageConsecutiveLosses Float?
  zScore                Float?
  ahpr                  Float?
  ghpr                  Float?
  finalBalance          Float?
  findingsCount         Int      @default(0)
  rawInputs             String?
  rawSettings           String?
  rawResults            String?
  rawOrders             String?
  rawDeals              String?
  warnings              String?
  importedAt            DateTime @default(now())
  deals                 Mt5Deal[]
  equityPoints          Mt5EquityPoint[]
  orders                Mt5Order[]
  findings              Mt5ReportFinding[]

  @@index([sessionId])
  @@index([importedAt])
}

model Mt5Order {
  id             String   @id @default(uuid())
  sessionId      String
  session        BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportImportId String
  reportImport   Mt5ReportImport @relation(fields: [reportImportId], references: [id], onDelete: Cascade)
  openTime       DateTime?
  orderId        String?
  symbol         String?
  type           String?
  volume         Float?
  price          Float?
  sl             Float?
  tp             Float?
  closeTime      DateTime?
  state          String?
  comment        String?

  @@index([sessionId])
  @@index([reportImportId])
  @@index([orderId])
}

model Mt5Deal {
  id             String   @id @default(uuid())
  sessionId      String
  session        BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportImportId String
  reportImport   Mt5ReportImport @relation(fields: [reportImportId], references: [id], onDelete: Cascade)
  time           DateTime?
  dealId         String?
  symbol         String?
  type           String?
  direction      String?
  positionId     String?
  volume         Float?
  price          Float?
  orderId        String?
  commission     Float?
  swap           Float?
  profit         Float?
  balance        Float?
  comment        String?

  @@index([sessionId])
  @@index([reportImportId])
  @@index([dealId])
  @@index([orderId])
  @@index([positionId])
}

model Mt5EquityPoint {
  id             String   @id @default(uuid())
  sessionId      String
  session        BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportImportId String
  reportImport   Mt5ReportImport @relation(fields: [reportImportId], references: [id], onDelete: Cascade)
  time           DateTime
  balance        Float
  equity         Float
  depositLoad    Float?

  @@index([sessionId])
  @@index([reportImportId])
  @@index([time])
}

model Mt5ReportFinding {
  id             String   @id @default(uuid())
  sessionId      String
  session        BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reportImportId String
  reportImport   Mt5ReportImport @relation(fields: [reportImportId], references: [id], onDelete: Cascade)
  severity       String
  title          String
  explanation    String
  suggestedFix   String?
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@index([reportImportId])
}

model DailyJournalNote {
  id         String   @id @default(uuid())
  scope      String   // BACKTEST_SESSION | LIVE_ACCOUNT
  contextId  String
  dateKey    String   // YYYY-MM-DD
  note       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scope, contextId, dateKey])
  @@index([scope, contextId])
  @@index([dateKey])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  source       String   @default("UNKNOWN")
  eventType    String
  payload      String
  dealId       String?  @unique // To prevent duplicate MT5 deal events
  receivedAt   DateTime @default(now())
  processed    Boolean  @default(false)
  error        String?

  // Legacy fields (optional to avoid breaking existing code if any)
  tradeId      String?
  status       String?
  errorMessage String?
}

model TradingViewSetup {
  id           String   @id @default(uuid())
  source       String   @default("tradingview")
  symbol       String
  timeframe    String
  side         String
  price        Float
  sl           Float?
  tp           Float?
  bodySize     Float?
  volume       Float?
  reason       String?
  chartUrl     String?
  previewUrl   String?
  payload      String
  status       String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | EXPIRED | EXECUTED
  expiresAt    DateTime
  reviewSource String?
  reviewNote   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@index([symbol, timeframe])
}

model InvalidTrade {
  id          String          @id @default(uuid())
  sessionId   String
  session     BacktestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tradeNumber Int
  reason      String
  rawRows     String          // JSON string of rows that caused error
  createdAt   DateTime        @default(now())

  @@index([sessionId])
}

model SystemSetting {
  key   String @id
  value String
}

model TradingAccount {
  id             String      @id @default(uuid())
  name           String
  broker         String?
  server         String?     // Keeping this for backwards compatibility, but we will mostly use brokerServer
  brokerServer   String?
  accountNumber  String?
  accountType    String      // DEMO | REAL | CENT | PROP | OTHER
  centMultiplier Float       @default(100)
  accountModel   String?     // Standard | Raw ECN | Cent | Pro | Demo | Other
  platform       String      @default("MANUAL") // MT5 | MT4 | Manual | Other
  leverage       String?
  status         String      @default("Active") // Active | Inactive | Archived
  currency       String
  initialBalance Float
  currentBalance Float
  currentEquity  Float?
  freeMargin     Float?
  lastSnapshotAt DateTime?
  notes          String?
  source         String      @default("MANUAL") // MANUAL | MT5_AUTO
  autoCreated    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  liveTrades     LiveTrade[]
}

model LiveTrade {
  id               String          @id @default(uuid())
  tradingAccountId String
  tradingAccount   TradingAccount  @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  source           String          // MANUAL | MT5_EA | MT5_PYTHON | BROKER_API
  positionId       String?         @unique // MT5 position ID
  symbol           String
  side             String          // BUY | SELL
  lot              Float
  entryPrice       Float
  stopLoss         Float?
  takeProfit       Float?
  closePrice       Float?
  openTime         DateTime
  closeTime        DateTime?
  rawMt5Time       Int?            // The original Unix timestamp sent by EA
  receivedAt       DateTime        @default(now()) // Backend received time
  status           String          @default("OPEN") // OPEN | CLOSED
  commission       Float?          @default(0)
  swap             Float?          @default(0)
  profit           Float?
  profitCurrency   String?
  riskMoney        Float?
  riskPercent      Float?
  rMultiple        Float?
  magicNumber      String?
  strategyTag      String?
  emotionTag       String?
  mistakeTag       String?
  notes            String?
  followedPlan     Boolean?
  screenshots      String?         // JSON string array of URLs
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tradingAccountId])
}

model RiskCalculationPreset {
  id           String   @id @default(uuid())
  name         String
  symbol       String
  pipSize      Float    // e.g., 0.0001 or 0.01
  tickSize     Float    // e.g., 0.00001
  tickValue    Float    // e.g., 1
  contractSize Float    @default(100000)
  lotStep      Float    @default(0.01)
  minLot       Float    @default(0.01)
  maxLot       Float    @default(100)
}

model AlertRule {
  id            String   @id @default(uuid())
  channel       String   // TELEGRAM | WHATSAPP | BOTH
  eventType     String   // TRADE_OPEN | TRADE_CLOSE | BALANCE_UPDATE | DRAWDOWN_LIMIT | DAILY_PROFIT_TARGET | DAILY_LOSS_LIMIT | MT5_DISCONNECTED
  enabled       Boolean  @default(true)
  thresholdValue Float?
  accountId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommandLog {
  id        String   @id @default(uuid())
  source    String   // TELEGRAM | WHATSAPP
  senderId  String
  command   String
  args      String?
  status    String   // RECEIVED | REJECTED | EXECUTED | FAILED
  response  String?
  createdAt DateTime @default(now())
}

model CommandQueue {
  id            String   @id @default(uuid())
  command       String
  args          String?
  accountId     String?
  status        String   @default("PENDING") // PENDING | APPROVED | SENT_TO_MT5 | EXECUTED | FAILED | EXPIRED
  targetEA      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IntegrationLog {
  id        String   @id @default(uuid())
  source    String   // MT5 | TELEGRAM | WHATSAPP_BAILEYS | WHATSAPP_CLOUD | SYSTEM
  eventType String
  status    String   // INFO | SUCCESS | WARNING | ERROR
  message   String
  details   String?  // JSON string
  createdAt DateTime @default(now())
}
